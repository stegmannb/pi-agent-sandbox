{
  "name": "pi-sandbox",
  "version": "0.1.0",
  "description": "OS-level sandboxing for pi with interactive permission prompts",
  "keywords": ["pi-package"],
  "type": "module",
  "pi": {
    "extensions": ["./index.ts"]
  },
  "scripts": {
    "fmt": "oxfmt index.ts",
    "lint": "oxlint index.ts",
    "check": "tsc --noEmit",
    "ci:fmt": "oxfmt --check index.ts",
    "ci:lint": "npm run lint",
    "ci:check": "npm run check"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.37"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/node": "^24",
    "oxfmt": "^0.33.0",
    "oxlint": "^1.48.0",
    "typescript": "^5"
  },
  "overrides": {
    "minimatch": ">=10.2.1"
  }
}
